rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ═══════════════════════════════════════════════════════════════════════
    // DEVELOPMENT RULES — allow all read/write without authentication
    // TODO: Replace with proper auth-based rules before production
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
