rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // By default, authenticated users can read all data.
    // Only Admin can write/modify the data.
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Guru Profile: allow guru to update their own document
    match /guru/{guruId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedDocId == guruId;
      allow create, delete: if isAdmin();
    }

    // Santri Profile: allow santri (wali santri) to update their own document
    // Only profile-editable fields are changed from the app; admin-managed fields
    // (nis, kelas, program, halaqohId, authUid) are never sent as writes from the client.
    match /santri/{santriId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedDocId == santriId;
      allow create, delete: if isAdmin();
    }
    
    // Exception: Users can read their own metadata
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId || isAdmin();
      allow write: if isAdmin();
    }

    // Absensi: allow authenticated Gurus to write attendance
    match /absensi/{documentId} {
      allow read, write: if isAuthenticated();
    }

    // Hafalan Santri: allow authenticated Gurus to write hafalan
    match /hafalan_santri/{documentId} {
      allow read, write: if isAuthenticated();
    }
  }
}
