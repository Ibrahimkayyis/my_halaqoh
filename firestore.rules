rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Function to check if user is a super admin.
    // Super Admin memiliki akses penuh (read + write + delete) ke SEMUA data.
    function isSuperAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Function to check if user is admin OR super_admin
    function isAdminOrSuperAdmin() {
      return isAdmin() || isSuperAdmin();
    }

    // ── Super Admin: akses penuh ke semua dokumen ─────────────────────────
    // Aturan ini match sebelum aturan spesifik di bawah — super_admin
    // diizinkan read+write di seluruh database tanpa pengecualian.
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Default: authenticated users bisa read semua data ────────────────
    // Only Admin can write/modify the data (selain super_admin di atas).
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Activity Log ─────────────────────────────────────────────────────
    match /activity_log/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSuperAdmin();
    }

    // Guru Profile: allow guru to update their own document
    match /guru/{guruId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedDocId == guruId;
      allow create, delete: if isAdmin();
    }

    // Santri Profile: allow santri (wali santri) to update their own document
    match /santri/{santriId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.linkedDocId == santriId;
      allow create, delete: if isAdmin();
    }

    // Exception: Users can read their own metadata.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId || isAdminOrSuperAdmin();
      allow write: if isAdminOrSuperAdmin();
      // Allow authenticated user to update their own FCM token fields only
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['fcmToken', 'fcmTokenUpdatedAt']);
      // Allow unauthenticated list with limit 1 — used by the login pre-check
      allow list: if request.auth == null && request.query.limit == 1;
    }

    // Absensi: allow authenticated Gurus to write attendance
    match /absensi/{documentId} {
      allow read, write: if isAuthenticated();
    }

    // Hafalan Santri: allow authenticated Gurus to write hafalan
    match /hafalan_santri/{documentId} {
      allow read, write: if isAuthenticated();
    }

    // Santri Extra Target: allow authenticated Gurus to add/update extra juz targets.
    match /santriExtraTarget/{santriId} {
      allow read, write: if isAuthenticated();
    }
  }
}
